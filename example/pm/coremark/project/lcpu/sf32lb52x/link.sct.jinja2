; Mirrors the legacy custom_mem_map.h layout used by the 52x CoreMark LCPU project.
{% set lcpu_code_window_size = 32 * 1024 %}
{% set lcpu_mbox_size = 2 * 512 %}
{% set lcpu_em_base = 0x20408000 %}
{% set lcpu_em_size = 24 * 1024 %}

LR_IROM1 {{ hex32(defines['__ROM_BASE']) }} {{ hex32(lcpu_code_window_size) }} {    ; load region size_region
  ER_IROM0 {{ hex32(defines['__ROM_BASE']) }} {{ hex32(lcpu_code_window_size) }} {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   core_list_join.o (+RO)
   core_main.o (+RO)
   core_matrix.o (+RO)
   core_state.o (+RO)
   core_util.o (+RO)
   main.o (.text.run_while_loop)
   .ANY2 (+RO)
  }
  ER_IROM1 +0   {  ; load address = execution address
   .ANY (+RO)
  }
  ScatterAssert((ImageLength(ER_IROM0)+ImageLength(ER_IROM1)+{{ hex32(lcpu_mbox_size) }})<{{ hex32(lcpu_code_window_size) }})

  RW_IRAM1 {{ hex32(lcpu_em_base) }} {{ hex32(lcpu_em_size) }} {  ; RW data
   .ANY (+RW +ZI)
  }
}
